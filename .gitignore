# Python — never push virtualenv (Playwright alone is >100MB; GitHub rejects)
.venv/
venv/
__pycache__/
*.pyc

# PyInstaller / local release builds (too large for GitHub; use Actions or Releases)
dist/
build/
*.dmg
*.zip
!extension-for-users/KDM-Browser-Extension.zip
*.tar.gz

# Build and Release Folders
bin-debug/
bin-release/
[Oo]bj/
[Bb]in/

# Other files and folders
.settings/

# Executables
*.swf
*.air
*.ipa
*.apk

# Project files, i.e. `.project`, `.actionScriptProperties` and `.flexProperties`
# should NOT be excluded as they contain compiler settings and other important
# information for Eclipse / Flash Builder.
